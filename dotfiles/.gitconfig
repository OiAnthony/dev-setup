[user]
	name = Your Name  # 请修改为你的名字
	email = your.email@example.com  # 请修改为你的邮箱

[core]
	editor = vim
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = false
	side-by-side = true

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[init]
	defaultBranch = main

[pull]
	rebase = false

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
